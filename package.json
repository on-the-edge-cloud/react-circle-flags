{
  "name": "react-circle-flags",
  "version": "0.0.27",
  "description": "A React component with a collection of 300+ minimal circular SVG country flags",
  "author": "Tomás Novau(tnovau@ontheedge.cloud)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/on-the-edge-cloud/react-circle-flags.git"
  },
  "main": "dist/index.js",
  "module": "dist/index.modern.js",
  "source": "src/index.js",
  "engines": {
    "node": ">=10"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "scripts": {
    "ci": "npm run lint && npm run build:test",
    "build": "vite build && shx cp index.d.ts dist/index.d.ts",
    "build:test": "npm run build",
    "start": "vite build --watch",
    "prepare": "npm run build",
    "test": "cross-env CI=1 react-scripts test --env=jsdom --coverage",
    "test:watch": "react-scripts test --env=jsdom",
    "lint": "eslint"
  },
  "peerDependencies": {
    "react": "^16.0.0 || 17.x || 18.x || 19.x"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^12.1.5",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^26.0.7",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^7.0.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^2.0.4",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "react-scripts": "^5.0.1",
    "request": "^2.88.2",
    "shx": "^0.3.2",
    "vite": "^8.0.1"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "react",
    "javascript",
    "npm",
    "component",
    "reactjs",
    "react-component",
    "react-components",
    "javascript-library",
    "flags",
    "countries",
    "react-component-library"
  ],
  "volta": {
    "node": "24.14.1"
  },
  "dependencies": {
    "eslint-plugin-testing-library": "^7.16.2"
  }
}
